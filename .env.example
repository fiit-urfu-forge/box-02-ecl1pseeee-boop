# =============================================================================
# DigitalBank — environment template
# Copy to .env and fill secrets. Never commit .env.
# =============================================================================

# ---- App -------------------------------------------------------------------
APP_NAME=DigitalBank
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# ---- Database (PostgreSQL 16) ----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=digitalbank
DB_USERNAME=digitalbank
DB_PASSWORD=

# ---- Redis 7 ---------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Session / Sanctum -----------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_DOMAIN=.localhost
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ---- Queue -----------------------------------------------------------------
QUEUE_CONNECTION=redis

# ---- Cache -----------------------------------------------------------------
CACHE_STORE=redis

# ---- Broadcast / Mail ------------------------------------------------------
BROADCAST_CONNECTION=log
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@digitalbank.ru
MAIL_FROM_NAME="${APP_NAME}"

# ---- Business rules (see §4.1 of SPEC) -------------------------------------
MIN_TRANSFER_AMOUNT=1.00
MAX_TRANSFER_AMOUNT=100000.00
DAILY_TRANSFER_LIMIT=300000.00
MAX_ACCOUNTS_PER_USER=5
IDEMPOTENCY_TTL_HOURS=24

# ---- Storage / Avatars -----------------------------------------------------
FILESYSTEM_DISK=local
AVATAR_MAX_SIZE_KB=5120

# ---- S3 (used only in prod) ------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=digitalbank-avatars
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- SBP gateway -----------------------------------------------------------
SBP_GATEWAY=mock
SBP_API_URL=
SBP_API_KEY=
SBP_WEBHOOK_SECRET=

# ---- Logging ---------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=info

# ---- Frontend (Next.js) ----------------------------------------------------
# Public base URL used by the browser; same-origin in local.
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost/api
# Internal URL used by Next.js SSR to reach Laravel from inside docker network.
INTERNAL_API_URL=http://app:9000

# ---- Docker / Postgres bootstrap ------------------------------------------
POSTGRES_DB=${DB_DATABASE}
POSTGRES_USER=${DB_USERNAME}
POSTGRES_PASSWORD=${DB_PASSWORD}
